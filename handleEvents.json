{
    "sections": [
        {
            "title": "VibeColorizer",
            "items": [
                {
                    "id": "enabled",
                    "name": "Включить",
                    "description": "Включает/отключает автоматическую подстройку цвета волны.",
                    "type": "button",
                    "value": true,
                    "defaultValue": true
                },
                {
                    "id": "intensity",
                    "name": "Максимальная интенсивность",
                    "description": "Максимальная сила изменения цвета (0 = выкл, 1 = полное изменение). Адаптивно снижается, если цвет уже близок.",
                    "type": "slider",
                    "min": 0,
                    "max": 1,
                    "step": 0.05,
                    "value": 0.85,
                    "defaultValue": 0.85
                },
                {
                    "id": "saturation",
                    "name": "Насыщенность волны",
                    "description": "Дополнительная насыщенность (1 = оригинальная, >1 = более насыщенная).",
                    "type": "slider",
                    "min": 0.5,
                    "max": 1.5,
                    "step": 0.05,
                    "value": 1,
                    "defaultValue": 1
                },
                {
                    "id": "brightness",
                    "name": "Базовая яркость волны",
                    "description": "Базовая яркость волны. К ней добавляется адаптивная коррекция (если включена).",
                    "type": "slider",
                    "min": 0.5,
                    "max": 1.5,
                    "step": 0.05,
                    "value": 1.3,
                    "defaultValue": 1.3
                },
                {
                    "id": "adaptiveBrightness",
                    "name": "Адаптивная яркость",
                    "description": "Автоматически регулировать яркость волны в зависимости от яркости обложки: светлые обложки → светлая волна, тёмные → тёмная волна.",
                    "type": "button",
                    "value": true,
                    "defaultValue": true
                },
                {
                    "id": "colorExtractionMethod",
                    "name": "Метод извлечения цвета",
                    "description": "Стандартный (сортировка по насыщенности), Сбалансированный (частота+насыщенность) или Альтернативный (гистограмма).",
                    "type": "selector",
                    "value": 1,
                    "options": {
                        "1": {
                            "event": "default",
                            "name": "Стандартный"
                        },
                        "2": {
                            "event": "balanced",
                            "name": "Сбалансированный"
                        },
                        "3": {
                            "event": "alternative",
                            "name": "Гистограммный"
                        }
                    },
                    "defaultValue": 1
                },
                {
                    "id": "saturationPreference",
                    "name": "Предпочтение насыщенности",
                    "description": "Подробности в README.",
                    "type": "slider",
                    "min": 0,
                    "max": 1,
                    "step": 0.05,
                    "value": 0.7,
                    "defaultValue": 0.7000000000000001
                },
                {
                    "id": "animationDuration",
                    "name": "Длительность анимации",
                    "description": "Время перехода при смене цвета (сек).",
                    "type": "slider",
                    "min": 0.1,
                    "max": 1.5,
                    "step": 0.05,
                    "value": 0.6,
                    "defaultValue": 0.6
                },
                {
                    "id": "specialNeutralHandling",
                    "name": "Спецобработка белых/чёрных/серых обложек",
                    "description": "Если включено, то для белых обложек волна становится светлее, для чёрных — отключается цвет (чёрно-белый эффект), для серых — слегка корректируется яркость. Если выключено — цвет волны не меняется для таких обложек.",
                    "type": "button",
                    "value": true,
                    "defaultValue": true
                },
                {
                    "id": "preload",
                    "name": "Предзагрузка обложек",
                    "description": "Загружать обложки следующих треков в очереди для плавного перехода.",
                    "type": "button",
                    "value": true,
                    "defaultValue": true
                },
                {
                    "id": "useFilterOnPause",
                    "name": "Не применять фильтр на паузе",
                    "description": "Если включено, то на паузе фильтр сбрасывается (волна возвращается к исходному цвету). Если выключено — фильтр остаётся активным даже на паузе.",
                    "type": "button",
                    "value": true,
                    "defaultValue": true
                },
                {
                    "id": "debug",
                    "name": "Режим отладки",
                    "description": "Включает подробный вывод в консоль для диагностики.",
                    "type": "button",
                    "value": false,
                    "defaultValue": false
                }
            ]
        }
    ]
}
